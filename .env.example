# Copy this file to .env for local development.
# Do not commit real secrets.

NGINX_HTTP_PORT=80

APP_VERSION=0.0.1-SNAPSHOT
GIT_COMMIT=unknown
BUILD_TIME=unknown
APP_ENV=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=guardian_plants
POSTGRES_USER=guardian_user
POSTGRES_PASSWORD=guardian_password

VOICEVOX_ENABLED=true
VOICEVOX_PORT=50021
VOICEVOX_BASE_URL=http://voicevox:50021

# AI provider configuration (used by server for /api/chat)
AI_BASE_URL=https://ollama.com/v1
AI_API_KEY=
AI_MODEL=gemma4:31b-cloud
AI_ACTIVE_PROFILE=default
AI_PROFILES_JSON=
# Example:
# AI_PROFILES_JSON=[{"id":"cloud-default","label":"Cloud default","baseUrl":"https://ollama.com/v1","apiKey":"","model":"gemma4:31b-cloud"},{"id":"ollama-gemma4-e2b","label":"AP Ollama gemma4:e2b","baseUrl":"http://host.docker.internal:11434/v1","apiKey":"ollama","model":"gemma4:e2b"}]

RATE_LIMIT_ENABLED=true
RATE_LIMIT_APP_START_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_TTS_PER_MINUTE=30

RETENTION_ENABLED=true
RETENTION_APP_LOGS_DAYS=30
RETENTION_CHAT_HISTORY_DAYS=90
RETENTION_PRUNE_ON_APP_START_EVERY=100

# Optional Basic Auth for /admin/* and admin write APIs.
# Leave password blank only for isolated local development.
ADMIN_AUTH_USERNAME=admin
ADMIN_AUTH_PASSWORD=

FLYWAY_ENABLED=true

JWT_SECRET=
