# Copy this file to .env for local development.
# Do not commit real secrets.

NGINX_HTTP_PORT=80

APP_VERSION=0.0.1-SNAPSHOT
GIT_COMMIT=unknown
BUILD_TIME=unknown
APP_ENV=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=guardian_plants
POSTGRES_USER=guardian_user
POSTGRES_PASSWORD=guardian_password

VOICEVOX_ENABLED=true
VOICEVOX_PORT=50021
VOICEVOX_BASE_URL=http://voicevox:50021

# AI provider configuration (used by server for /api/chat)
AI_BASE_URL=https://ollama.com/v1
AI_API_KEY=
AI_MODEL=gemma4:31b-cloud

RATE_LIMIT_ENABLED=true
RATE_LIMIT_APP_START_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_TTS_PER_MINUTE=30

RETENTION_ENABLED=true
RETENTION_APP_LOGS_DAYS=30
RETENTION_CHAT_HISTORY_DAYS=90
RETENTION_PRUNE_ON_APP_START_EVERY=100

FLYWAY_ENABLED=true

JWT_SECRET=
